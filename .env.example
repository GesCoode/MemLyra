# --- Local dev (npm run dev) ---
# 1. cp .env.example .env
# 2. docker compose up -d db
# 3. npm run dev  →  http://localhost:5173
# 4. Log in: admin / admin  (auto-seeded dev account)

POSTGRES_PASSWORD=memlyra
SESSION_SECRET=local-dev-session-secret-not-for-production
ORIGIN=http://localhost:5173
DATABASE_URL=postgres://memlyra:memlyra@localhost:5432/memlyra

# --- Production (docker compose up -d --build) ---
# POSTGRES_PASSWORD=change-me-to-a-long-random-password
# SESSION_SECRET=change-me-to-another-long-random-string
# ORIGIN=https://memlyra.com
# DATABASE_URL is set automatically in docker-compose for the app container.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MemLyra <noreply@gesmoo.com>
